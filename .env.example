# HKBU GenAI API
HKBU_API_KEY=your_api_key_here
HKBU_BASE_URL=https://genai.hkbu.edu.hk/api/v0/rest
HKBU_MODEL_NAME=gpt-4.1
HKBU_API_VERSION=2024-12-01-preview

# Memory Constraints
MAX_TOKENS_PER_SUBQUERY=2000
MAX_TOKENS_PER_SESSION=10000
MAX_SUBQUESTIONS=5

# Web Search (DuckDuckGo, free, no API key needed)
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5

# Memory Service
MEMORY_SERVICE_HOST=0.0.0.0
MEMORY_SERVICE_PORT=8100
CHROMA_PERSIST_DIR=./chroma_data

# Dify (for reference when configuring Dify UI)
# DIFY_URL=http://localhost
# DIFY_API_KEY=your_dify_api_key
