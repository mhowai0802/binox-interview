# Deep Research Agent (G3) — Setup Configuration
# Copy to .env and fill in your API keys before running ./setup.sh

# ── Dify ──────────────────────────────────────────
DIFY_URL=http://localhost

# Admin account (created automatically on first run)
DIFY_ADMIN_EMAIL=admin@example.com
DIFY_ADMIN_NAME=Admin
DIFY_ADMIN_PASSWORD=Admin123456

# ── LLM Provider ─────────────────────────────────
# Choose: "openai" or "hkbu"
LLM_PROVIDER=hkbu

# HKBU GenAI API (required if LLM_PROVIDER=hkbu)
HKBU_API_KEY=your-hkbu-api-key-here
HKBU_LLM_MODEL=gpt-4.1
HKBU_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
